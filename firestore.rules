rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard rule for the user's main document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicitly allow access to the apiKeys subcollection
      match /apiKeys/{keyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
